# CockroachDB connection string (from CockroachDB Cloud Console)
DATABASE_URL=postgresql://user:password@host:26257/defaultdb?sslmode=verify-full

# Session encryption key (generate with: openssl rand -base64 32)
NUXT_SESSION_PASSWORD=your-32-char-random-string-here

# Google OAuth (from Google Cloud Console)
NUXT_OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Comma-separated admin emails (first admin auto-created)
ADMIN_EMAILS=admin@sahrdaya.ac.in
